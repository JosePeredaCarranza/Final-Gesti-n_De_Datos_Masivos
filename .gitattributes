# Archivos de texto normalizados en el repositorio
* text=auto
# Código y configuración: siempre LF
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
# Scripts específicos de Windows
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
# Archivos binarios
*.parquet binary
*.exe binary
*.dll binary
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.zip binary
*.pbix filter=lfs diff=lfs merge=lfs -text
